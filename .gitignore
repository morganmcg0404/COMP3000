# Compiled object files
*.o
*.obj
*.exe
*.dll
*.so
*.dylib

# Unity generated files
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
_[Rr]ecovery/

